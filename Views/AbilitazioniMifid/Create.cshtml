@model AbilitazioneMifidCreateInputModel
<h3>@ViewData["Title"]</h3>
<form method="post" class="mt-4">
    <div class="row">
        <div class="col-md-10 col-lg-8"> 
            <label class="form-label fw-bold text-secondary">Seleziona Dipendente</label>
            <div class="d-flex align-items-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-circle" style="height: 38px;" title="Torna alla lista">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <div class="flex-grow-1">
                    <select id="select-dipendente" 
                            name="Matricola" 
                            placeholder="Inizia a scrivere nome o matricola..." 
                            autocomplete="off" 
                            required>
                        <option value=""></option>
                    </select>
                </div>
                <button type="submit" class="btn btn-outline-success btn-sm px-4" title="Conferma la creazione" style="height: 38px;">
                    <i class="fas fa-rocket me-2"></i>Crea
                </button>
            </div>
            <span asp-validation-for="Matricola" class="text-danger"></span>
        </div>
    </div>
</form>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        new TomSelect("#select-dipendente", {
            valueField: 'value',
            labelField: 'text',
            searchField: 'text',
            preload: true,
            hideSelected: true,
            load: function(query, callback) {
                var url = '@Url.Action("GetAnagDipendenti", "AbilitazioniMifid")';
                
                fetch(url)
                    .then(response => response.json())
                    .then(json => {
                        callback(json);
                    })
                    .catch(err => {
                        callback();
                    });
            }
        });
    });
</script>