@model AbilitazioneMifidDetailViewModel
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div class="d-flex align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle me-3" title="Torna all'elenco" style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h3 class=mb-0>
                @ViewData["Title"]:
                <span class="text-primary position-relative">
                    @Model.Intestazione

                    @if (@Model.Escluso == true)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                            style="font-size: 0.5rem; padding: 0.35em 0.65em;">
                            ESCLUSO
                            <span class="visually-hidden">Stato disabilitato</span>
                        </span>
                    }
                </span>
            </h3>

            <a class="btn btn-outline-primary btn-sm ms-3" asp-action="Edit" asp-route-matricola="@Model.Matricola">
                <i class="fas fa-pencil-alt me-2"></i>Modifica
            </a>
        </div>
        <span class="badge bg-secondary">
            Ultimo aggiornamento: @Model.DataUltimoAggiornamento?.ToString("dd/MM/yyyy")
        </span>
    </div>

    <div class="row g-4">
        <div class="col-lg-5 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-light fw-bold"><i class="fas fa-user me-2"></i>Dati Generali</div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted small">Unità Organizzativa</div>
                        <div class="col-sm-8 fw-bold">@Model.DescrUO</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted small">Codice Fiscale</div>
                        <div class="col-sm-8 font-monospace">@Model.CodiceFiscale</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted small">Ruolo</div>
                        <div class="col-sm-8">
                            <span class="text-dark">@Model.Ruolo</span>
                        </div>
                    </div>
                    <hr />
                    <div class="row mb-3">
                        <div class="col-12 text-muted small uppercase">Titolo di studio</div>
                        <div class="col-12 fw-bold">@Model.TitoloStudio</div>
                        <div class="col-12 text-muted small">Conseguito il: @Model.DataConseguimentoTitoloStudio?.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="mb-1 text-center">
                        @if (Model.AbilitatoFinanceWMP == true)
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle me-1"></i> WMP abilitato
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                <i class="bi bi-x-circle me-1"></i> WMP non abilitato
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7 mb-4">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-header bg-primary text-white fw-bold"><i class="fas fa-balance-scale me-2"></i>Status MIFID</div>
                    <div class="card-body">
                        <div class="mb-4 p-2 bg-light border-start border-primary border-4 rounded-end">
                            <label class="text-muted small d-block fw-bold">Titolo di studio MiFID</label>
                            <span class="h6 mb-0">@Html.Raw(Model.TitoloStudioMifid)</span>
                        </div>

                        <div class="row g-0">
                            <div class="col-md-3 text-muted small">
                                <div style="height: 40px;">Abilitazione Mifid</div>
                                <div style="height: 40px;">Assessment</div>
                            </div>

                            <div class="col-md-3 border-end pe-4">
                                <div style="height: 40px;" class="fw-bold">
                                    @Model.DataAbilitazioneMifid?.ToString("dd/MM/yyyy")
                                </div>
                                <div style="height: 40px;">
                                    @if (Model.NecessarioAssessment == false) { <span class="text-muted">Non necessario</span> }
                                    else if (Model.DataSuperamentoAssessment.HasValue) { <span class="text-success fw-bold">@Model.DataSuperamentoAssessment.Value.ToString("dd/MM/yyyy")</span> }
                                    else { <span class="text-danger fw-bold">Da superare</span> }
                                </div>
                            </div>

                            <div class="col-md-3 text-muted small ps-4">
                                <div style="height: 40px;">Abilitazione titoli</div>
                                <div style="height: 40px;">Anni esperienza</div>
                            </div>

                            <div class="col-md-3">
                                <div style="height: 40px;" class="fw-bold">
                                    @Model.DataAbilitazioneTitoli?.ToString("dd/MM/yyyy")
                                </div>
                                <div style="height: 40px;">
                                    <span class="badge rounded-pill bg-dark">@Model.AnniEsperienzaAdeguata</span>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning py-2 small mt-2 mb-0">
                            <strong>Sospensione: </strong> 
                            @(Model.DataSospensione.HasValue ? $"{Model.DataSospensione:dd/MM/yyyy} - {Model.DataTermineSospensione:dd/MM/yyyy}" : "Nessuna")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light fw-bold"><i class="fas fa-users-cog me-2"></i>Supervisione</div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3 border-end">
                            <div class="text-muted small">Periodo</div>
                            <div class="fw-bold">@Model.MesiPeriodoSupervisione mesi</div>
                            <div class="small text-muted text-center">
                                @Model.DataInizioSupervisione?.ToString("dd/MM/yyyy")
                                @if (Model.DataFineSupervisione.HasValue)
                                {
                                    <span> - @Model.DataFineSupervisione.Value.ToString("dd/MM/yyyy")</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-4 border-end">
                            <div class="text-muted small">Supervisore</div>
                            <div class="fw-bold text-primary">@Model.IntestazioneSupervisore</div>
                            <div class="small">@Model.MatricolaSupervisore</div>
                        </div>
                        <div class="col-md-5">
                            <div class="text-muted small">Sostituto supervisore</div>
                            <div class="fw-bold">@Model.IntestazioneSostitutoSupervisore</div>
                            <div class="small text-muted">@Model.MatricolaSostitutoSupervisore</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-8 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light fw-bold"><i class="fas fa-sticky-note me-2"></i>Note e Formazione</div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6 border-end">
                                <label class="text-muted small d-block">Formazione 2024</label>
                                <p class="fw-bold">@Model.Formazione2024</p>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small d-block">Formazione 2025</label>
                                <p class="fw-bold">@Model.Formazione2025</p>
                            </div>
                        </div>
                        <label class="text-muted small d-block">Note generali</label>
                        <p class="fst-italic text-secondary">@(Model.Note ?? "Nessuna nota presente")</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100 bg-light">
                    <div class="card-header fw-bold text-center">Creazione Lettere</div>
                    <div class="card-body d-grid gap-2">
                        <button class="btn btn-outline-primary btn-sm"><i class="fas fa-file-pdf me-2"></i>Lettera X @Model.GeneraLetteraX</button>
                        <button class="btn btn-outline-primary btn-sm"><i class="fas fa-file-pdf me-2"></i>Lettera Y @Model.GeneraLetteraY</button>
                        <button class="btn btn-outline-primary btn-sm"><i class="fas fa-file-pdf me-2"></i>Lettera Z @Model.GeneraLetteraZ</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>