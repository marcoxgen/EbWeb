@model AbilitazioneMifidEditInputModel
<section class="abilitazione-info container py-4">
    <form method="post">
        <div class="mb-2 pb-0">
            <div class="d-flex align-items-center">
                <a asp-action="Detail" asp-route-matricola="@Model.Matricola"
                class="btn btn-outline-secondary btn-sm rounded-circle me-3"
                title="Annulla e torna indietro"
                style="width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center;">
                    <i class="fas fa-arrow-left" style="font-size: 0.8rem;"></i>
                </a>

                <h3 class="mb-0">
                    @ViewData["Title"]: <span class="text-primary">@Model.Intestazione</span>
                </h3>

                <button type="submit" class="btn btn-outline-success btn-sm px-3 ms-3">
                    <i class="fas fa-save me-2"></i>Salva
                </button>
            </div>

            <div class="d-flex justify-content-end mt-2">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchEscluso"
                        name="Escluso" value="true"
                        @(Model.Escluso == true ? "checked" : "") style="cursor:pointer;">
                    <input type="hidden" name="Escluso" value="false">
                    <label class="form-check-label text-primary small fw-semibold" for="switchEscluso" style="cursor:pointer;">
                        Escludi
                    </label>
                </div>
            </div>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Matricola">

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card h-100 shadow-sm">
                    <div class="card-header bg-light fw-bold">
                        <i class="fas fa-user me-2"></i>Dati Generali   
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="TitoloStudio" class="form-label text-muted small"></label>
                            <input type="text" class="form-control" asp-for="TitoloStudio" placeholder="Es. Laurea in Economia" >
                            <span asp-validation-for="TitoloStudio" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DataConseguimentoTitoloStudio" class="form-label text-muted small"></label>
                            <input type="date" class="form-control" asp-for="DataConseguimentoTitoloStudio">
                            <span asp-validation-for="DataConseguimentoTitoloStudio" class="text-danger small"></span>
                        </div>

                        <div class="row mb-0 align-items-end">
                            <div class="col-lg-6">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" id="switchAbilitatoWMP"
                                        name="Abilitato_Finance_WMP" value="true"
                                        @(Model.Abilitato_Finance_WMP == true ? "checked" : "")>
                                    <input type="hidden" name="Abilitato_Finance_WMP" value="false">
                                    <label class="form-check-label text-muted small" asp-for="Abilitato_Finance_WMP" for="switchAbilitatoWMP"></label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="card h-100 shadow-sm border-primary">
                    <div class="card-header bg-primary text-white fw-bold">
                        <i class="fas fa-balance-scale me-2"></i>Status MiFID
                    </div>
                    <div class="card-body">
                        <div class="row g-0"> <div class="col-lg-9 border-end pe-3"> 
                                <div class="mb-3">
                                    <label asp-for="TitoloStudioMifidCod" class="form-label fw-bold text-primary small"></label>
                                    <select id="select-titoli" asp-for="TitoloStudioMifidCod" autocomplete="off"></select>
                                </div>

                                <div class="row g-0 p-2 border border-warning rounded bg-warning bg-opacity-10">
                                    <div class="col-lg-6 pe-2">
                                        <label asp-for="DataSospensione" class="form-label small fw-bold"></label>
                                        <input type="date" class="form-control form-control-sm" asp-for="DataSospensione">
                                    </div>
                                    <div class="col-lg-6">
                                        <label asp-for="DataTermineSospensione" class="form-label small fw-bold"></label>
                                        <input type="date" class="form-control form-control-sm" asp-for="DataTermineSospensione">
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 ps-3">
                                <div class="mb-2">
                                    <label asp-for="DataAbilitazioneMifid" class="form-label text-muted small mb-0"></label>
                                    <input type="date" class="form-control form-control-sm" asp-for="DataAbilitazioneMifid">
                                </div>
                                <div class="mb-4">
                                    <label asp-for="DataAbilitazioneTitoli" class="form-label text-muted small mb-0"></label>
                                    <input type="date" class="form-control form-control-sm" asp-for="DataAbilitazioneTitoli">
                                </div>
                                <div class="mb-0">
                                    <div class="form-check form-switch mb-1">
                                        <input class="form-check-input" type="checkbox" role="switch" id="switchAssessment"
                                            name="NecessarioAssessment" value="true"
                                            @(Model.NecessarioAssessment == true ? "checked" : "")>
                                        
                                        <input type="hidden" name="NecessarioAssessment" value="false">

                                        <label class="form-check-label small text-muted" for="switchAssessment">
                                            Assessment
                                        </label>
                                    </div>
                                    @if (Model.NecessarioAssessment == true)
                                    {
                                        <input type="date" class="form-control form-control-sm" 
                                            id="inputDataAssessment" asp-for="DataSuperamentoAssessment">
                                    }
                                    else
                                    {
                                        <input type="date" class="form-control form-control-sm" 
                                            id="inputDataAssessment" asp-for="DataSuperamentoAssessment" disabled>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-light fw-bold"><i class="fas fa-users-cog me-2"></i>Supervisione</div>
                    <div class="card-body form-label small">
                        <div class="row">
                            <div class="col-lg-2">
                                <label asp-for="DataInizioSupervisione" class="form-label small fw-bold"></label>
                                <input type="date" class="form-control" asp-for="DataInizioSupervisione">
                            </div>
                            <div class="col-lg-2">
                                <label asp-for="DataFineSupervisione" class="form-label small fw-bold"></label>
                                <input type="date" class="form-control" asp-for="DataFineSupervisione">
                            </div>
                            <div class="col-lg-4">
                                <label asp-for="MatricolaSupervisore" class="form-label small fw-bold"></label>
                                <select id="select-supervisore" asp-for="MatricolaSupervisore"></select>
                            </div>
                            <div class="col-lg-4">
                                <label asp-for="MatricolaSostitutoSupervisore" class="form-label small fw-bold"></label>
                                <select id="select-sostituto" asp-for="MatricolaSostitutoSupervisore"></select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-light fw-bold"><i class="fas fa-sticky-note me-2"></i>Note e Formazione</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-6 mb-3">
                                <label asp-for="Formazione2024" class="form-label small fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-graduation-cap"></i></span>
                                    <input type="text" class="form-control" asp-for="Formazione2024">
                                </div>
                            </div>
                            <div class="col-lg-6 mb-3">
                                <label asp-for="Formazione2025" class="form-label small fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-graduation-cap"></i></span>
                                    <input type="text" class="form-control" asp-for="Formazione2025">
                                </div>
                            </div>
                        </div>

                        <textarea asp-for="Note" class="form-control" rows="3" placeholder="Aggiungi eventuali annotazioni..."></textarea>
                    </div>
                </div>
            </div>
        </div>
    </form>
</section>

<div class="modal fade" id="modalConfermaEscluso" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Conferma Esclusione</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Sei sicuro di voler escludere questo utente dalle abilitazioni MiFID? 
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="btnAnnullaEsclusione">Annulla</button>
                <button type="button" class="btn btn-warning" id="btnConfermaEsclusione">Sì, escludi</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function (event) {
        function initTomSelect(selector, url, initialValue) {
            const el = document.querySelector(selector);
            if (!el) return;

            const ts = new TomSelect(selector, {
                valueField: 'value',
                labelField: 'text',
                searchField: 'text',
                preload: true,
                hideSelected: true,
                load: function(query, callback) {
                    fetch(url)
                        .then(response => response.json())
                        .then(json => {
                            callback(json);
                            if (initialValue && initialValue !== "") {
                                ts.addItem(initialValue);
                            }
                        }).catch(() => callback());
                }
            });
        }

        initTomSelect("#select-titoli",
                      '@Url.Action("GetTitoliStudioMifid", "AbilitazioniMifid")',
                      "@Model.TitoloStudioMifidCod?.ToString()");
        initTomSelect("#select-supervisore",
                      '@Url.Action("GetSupervisori", "AbilitazioniMifid")',
                      "@Model.MatricolaSupervisore?.ToString()");
        initTomSelect("#select-sostituto",
                      '@Url.Action("GetSupervisori", "AbilitazioniMifid")',
                      "@Model.MatricolaSostitutoSupervisore?.ToString()");

        const swEscluso = document.getElementById('switchEscluso');
        const modalElement = new bootstrap.Modal(document.getElementById('modalConfermaEscluso'));
        const btnConferma = document.getElementById('btnConfermaEsclusione');
        const btnAnnulla = document.getElementById('btnAnnullaEsclusione');

        swEscluso.addEventListener('click', function(e) {
            if (this.checked) {
                e.preventDefault();
                modalElement.show();
            }
        });

        btnConferma.addEventListener('click', function() {
            swEscluso.checked = true;
            modalElement.hide();
        });

        const chiudiModale = () => {
            swEscluso.checked = false;
            modalElement.hide();
        };

        btnAnnulla.addEventListener('click', chiudiModale);
        document.getElementById('modalConfermaEscluso').addEventListener('hidden.bs.modal', function() {
            if (!swEscluso.checked) swEscluso.checked = false; 
        });

        // Gestione abilitazione/disabilitazione DataSuperamentoAssessment
        const swAssessment = document.getElementById('switchAssessment');
        const inputDataAssessment = document.getElementById('inputDataAssessment');

        swAssessment.addEventListener('change', function() {
            inputDataAssessment.disabled = !this.checked;
        });
    });
</script>