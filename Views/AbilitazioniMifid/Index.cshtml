@model AbilitazioneMifidListViewModel
<div class="row align-items-center mb-4">
    <div class="col-md-8 d-flex align-items-center">
        <h1 class="mb-0 me-3">@ViewData["Title"]</h1>
        <a class="btn btn-success btn-sm" asp-action="Create">
            <i class="fa fa-plus"></i> Crea nuovo
        </a>
    </div>

    <div class="col-md-4">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Cerca..." value="@Model.Input.Search">
                <button class="btn btn-outline-secondary" type="submit">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="container bg-light p-4 rounded shadow-sm">
    <div class="row">
        <div class="col-md-1"><a asp-route-orderby="Matricola" asp-route-ascending="@(Model.Input.OrderBy == "Matricola" ? !Model.Input.Ascending : true)" asp-route-search="@Model.Input.Search">Matricola @if(Model.Input.OrderBy == "Matricola") { <i class="fas fa-caret-@(Model.Input.Ascending ? "up" : "down")"></i> }</a></div>
        <div class="col-md-2"><a asp-route-orderby="Intestazione" asp-route-ascending="@(Model.Input.OrderBy == "Intestazione" ? !Model.Input.Ascending : true)" asp-route-search="@Model.Input.Search">Intestazione @if(Model.Input.OrderBy == "Intestazione") { <i class="fas fa-caret-@(Model.Input.Ascending ? "up" : "down")"></i> }</a></div>
        <div class="col-md-3">Descrizione UO</div>
        <div class="col-md-1">Ruolo</div>
        <div class="col-md-1">Abil. Mifid</div>
        <div class="col-md-1">Data Abil.</div>
        <div class="col-md-1">Ult. Agg.</div>
    </div>

    @foreach (AbilitazioneMifidViewModel abilitazione in Model.AbilitazioniMifid.Results)
    {
        <div class="row border-bottom py-2 align-items-center">
            <div class="col-md-1">
                <span>@abilitazione.Matricola</span>
            </div>
            <div class="col-md-2">
                <span>@abilitazione.Intestazione</span>
            </div>
           <div class="col-md-3">
                <span>@abilitazione.DescrUO</span>
            </div>
            <div class="col-md-1">
                <span>@abilitazione.Ruolo</span>
            </div>
            <div class="col-md-1 text-center">
                <span>@abilitazione.FlagAbilitatoMifid</span>
            </div>
            <div class="col-md-1">
                <span>@abilitazione.DataAbilitazioneMifid</span>
            </div>
            <div class="col-md-1">
                <span>@abilitazione.DataUltimoAggiornamento</span>
            </div>
            <div class="col-md-2 d-flex align-items-center">
                <a class="btn btn-outline-primary btn-sm" asp-controller="AbilitazioniMifid" asp-action="Detail" asp-route-matricola="@abilitazione.Matricola"><i class="fas fa-file-alt"></i> Dettaglio</a>
            </div>
        </div>
    }
</div>

@{
    int totalPages = (int) Math.Ceiling(Model.AbilitazioniMifid.TotalCount / (decimal) Model.Input.Limit);
    int currentPage = Model.Input.Page;
}
<nav aria-label="Paginazione">
    <ul class="pagination d-flex justify-content-center mt-3">
        @if(currentPage > 1)
        {
            <li class="page-item">
                <a class="page-link" asp-route-page="@(currentPage - 1)" asp-route-search="@Model.Input.Search" asp-route-orderby="@Model.Input.OrderBy" asp-route-ascending="@Model.Input.Ascending"><i class="fas fa-angle-left"></i></a>
            </li>   
        }
        @for(int p = Math.Max(1, currentPage - 4); p <= Math.Min(totalPages, currentPage + 4); p++)
        {
            if (p == currentPage)
            {
                <li class="page-item active" aria-current="page">
                    <a class="page-link" asp-route-page="@p" asp-route-search="@Model.Input.Search" asp-route-orderby="@Model.Input.OrderBy" asp-route-ascending="@Model.Input.Ascending">@p <span class="sr-only">(current)</span></a>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link" asp-route-page="@p" asp-route-search="@Model.Input.Search" asp-route-orderby="@Model.Input.OrderBy" asp-route-ascending="@Model.Input.Ascending">@p</a>
                </li>
            }
        }
        @if(currentPage < totalPages)
        {
            <li class="page-item">
                <a class="page-link" asp-route-page="@(currentPage + 1)" asp-route-search="@Model.Input.Search" asp-route-orderby="@Model.Input.OrderBy" asp-route-ascending="@Model.Input.Ascending"><i class="fas fa-angle-right"></i></a>
            </li>   
        }
    </ul>
</nav>