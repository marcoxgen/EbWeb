@model AnomaliaRegistrazioneViewModel
@{
    ViewBag.Title = "Forza Anomalia";
}

<div class="container mt-5">
    <div class="card shadow p-4">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-1">Forza Anomalia</h2>
            <p class="mb-0">@Model.Nag</p>
        </div>
        <div class="card-body text-center">
            <strong>ATTENZIONE:</strong> Vuoi veramente forzare l'anomalia inerente
            <br /><strong>@Model.Intestazione</strong>
            <br /><strong>@Model.CodiceFiscale</strong>
            <br /><small>in questo modo il soggetto verrà registrato nonostante la mancata corrispondenza nei recapiti.</small>
        </div>
        <div class="d-flex justify-content-center gap-5 mt-4">
            <form asp-action="EseguiForzatura" asp-route-id="@Model.Nag" method="post">
                <button type="submit" class="btn btn-success btn-lg rounded-circle" style="width: 100px; height: 100px;">
                    <i class="fas fa-check" style="font-size: 80px; color: white;"></i>
                </button>
            </form>
            <form asp-action="AnnullaForzatura" method="post">
                <button type="submit" class="btn btn-danger btn-lg rounded-circle" style="width: 100px; height: 100px;">
                    <i class="fas fa-xmark" style="font-size: 80px; color: white;"></i>
                </button>
            </form>
        </div>
        <div class="text-center mt-4">
            <small class="text-muted">Sarà comunque possibile visualizzare l'anomalia nell'apposita sezione.</small>
        </div>
    </div>
</div>
