@model IstruttoriaListViewModel

@Html.AntiForgeryToken() <!-- CSRF token -->

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white d-flex align-items-center">
        <i class="fas fa-tasks me-2"></i>
        <h3 class="mb-0">@ViewData["Title"]</h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-sm table-small-text" style="table-layout: fixed; min-width: 1800px;">
                <thead class="bg-light text-primary text-center">
                    <tr>
                        <th style="width: 80px;">NAG</th>
                        <th style="width: 250px;">Intestazione</th>
                        <th style="width: 120px;">Numero Pratica</th>
                        <th style="width: 150px;">Cluster Pratica</th>
                        <th style="width: 80px;">Data Lavor Ricalcolata</th>
                        <th style="width: 150px;">Gestore</th>
                        <th style="width: 50px;">Rating</th>
                        <th style="width: 150px;">Istruttore</th>
                        <th style="width: 120px;">Azioni</th>
                        <th style="width: 250px;">Note</th>
                        <th style="width: 250px;">Note Escalation Indicatori Bilancio</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var istruttoria in Model.Istruttorie.Results)
                    {
                        <tr>
                            <td>@istruttoria.Nag</td>
                            <td>@istruttoria.Intestazione</td>
                            <td>@istruttoria.NumeroPratica</td>
                            <td>@istruttoria.ClusterPratica</td>
                            <td class="text-center">@istruttoria.EliminaCode</td>
                            <td>@istruttoria.Gestore</td>
                            <td class="text-center">@istruttoria.Rating</td>
                            <td class="istruttore">@istruttoria.Istruttore</td> <!-- Aggiunta classe -->
                            <td class="azioni d-flex justify-content-center">
                                <button class="btn btn-sm @(string.IsNullOrEmpty(istruttoria.Istruttore) ? "btn-outline-success" : "btn-outline-danger") btn-toggle-istruttore flex-fill" style="max-width: 100px;">
                                    <i class="fas @(string.IsNullOrEmpty(istruttoria.Istruttore) ? "fa-user-plus" : "fa-user-times")"></i>
                                    @(string.IsNullOrEmpty(istruttoria.Istruttore) ? "Assegna" : "Revoca")
                                </button>
                            </td>
                            <td>@istruttoria.Note</td>
                            <td>@istruttoria.NoteEscalationIndicatoriBilancio</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @{
        int totalPages = (int) Math.Ceiling(Model.Istruttorie.TotalCount / (decimal) Model.Input.Limit);
        int currentPage = Model.Input.Page;
    }

    @if (totalPages > 1)
    {
        <div class="card-footer d-flex justify-content-center">

            <nav aria-label="Paginazione">
                <ul class="pagination d-flex justify-content-center mt-3">
                    @if(currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-page="@(currentPage - 1)"><i class="fas fa-angle-left"></i></a>
                        </li>   
                    }
                    @for(int p = Math.Max(1, currentPage - 4); p <= Math.Min(totalPages, currentPage + 4); p++)
                    {
                        if (p == currentPage)
                        {
                            <li class="page-item active" aria-current="page">
                                <a class="page-link" asp-route-page="@p">@p <span class="sr-only">(current)</span></a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" asp-route-page="@p">@p</a>
                            </li>
                        }
                    }
                    @if(currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-page="@(currentPage + 1)"><i class="fas fa-angle-right"></i></a>
                        </li>   
                    }
                </ul>
            </nav>
        </div>
    }
</div>

<!-- SCRIPT AJAX ASSEGNA/REVOCA -->
@section Scripts {
    <script>
        const assignUrl = '@Url.Action("Assign", "Istruttorie")';
        const revokeUrl = '@Url.Action("Revoke", "Istruttorie")';

        document.querySelectorAll(".btn-toggle-istruttore").forEach(function(button) {
            button.addEventListener("click", async function () {
                var row = button.closest("tr");
                if (!row) return;

                var numeroPratica = row.querySelector("td:nth-child(3)").textContent.trim();
                var cell = row.querySelector(".istruttore");
                if (!cell) return;

                var actionUrl = button.classList.contains("btn-outline-success") ? assignUrl : revokeUrl;

                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                var formData = new FormData();
                formData.append("__RequestVerificationToken", token);
                formData.append("numeroPratica", numeroPratica);

                try {
                    var response = await fetch(actionUrl, {
                        method: "POST",
                        body: formData
                    });

                    if (!response.ok) throw new Error(`Server error: ${response.status}`);
                    var data = await response.json();

                    if (actionUrl === assignUrl) {
                        cell.textContent = data.istruttore;
                        button.classList.remove("btn-outline-success");
                        button.classList.add("btn-outline-danger");
                        button.innerHTML = '<i class="fas fa-user-times"></i> Revoca';
                    } else {
                        cell.textContent = "";
                        button.classList.remove("btn-outline-danger");
                        button.classList.add("btn-outline-success");
                        button.innerHTML = '<i class="fas fa-user-plus"></i> Assegna';
                    }
                } catch (err) {
                    console.error("Fetch error:", err);
                    alert("Errore di rete. Controlla token CSRF o connessione.");
                }
            });
        });
    </script>
}