@model AgendaStipulaListViewModel

@Html.AntiForgeryToken() <!-- CSRF token -->

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white d-flex align-items-center">
        <i class="fas fa-tasks me-2"></i>
        <h3 class="mb-0">@ViewData["Title"]</h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-sm table-small-text" style="table-layout: fixed; min-width: 1200px;">
                <thead class="bg-light text-primary text-center">
                    <tr>
                        <th style="width: 30px;">Id</th>
                        <th style="width: 70px;">Data Prenotazione</th>
                        <th style="width: 40px;">Filiale</th>
                        <th style="width: 50px;">Nag</th>
                        <th style="width: 100px;">Intestazione</th>
                        <th style="width: 170px;">Descrizione Prodotto</th>
                        <th style="width: 60px;">Tipo Atto</th>
                        <th style="width: 60px;">Importo Deliberato</th>
                        <th style="width: 40px;">Mutuo SAL</th>
                        <th style="width: 100px;">Assegnatario</th>
                        <th style="width: 80px;">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agendaStipula in Model.AgendaStipule.Results)
                    {
                        <tr>
                            <td>@agendaStipula.IdRichiesta</td>
                            <td>@agendaStipula.DataRichiesta.ToString(format: "d")</td>
                            <td>@agendaStipula.Filiale</td>
                            <td>@agendaStipula.Nag</td>
                            <td>@agendaStipula.Intestazione</td>
                            <td>@agendaStipula.DescrizioneProdotto</td>
                            <td>@agendaStipula.TipoAtto</td>
                            <td>@(string.IsNullOrEmpty(agendaStipula.ImportoDeliberato) ? "0" : agendaStipula.ImportoDeliberato.Split(',')[0])</td>
                            <td>@agendaStipula.MutuoSAL</td>
                            <td class="assegnatario">@agendaStipula.Assegnatario</td>
                            <td class="azioni d-flex justify-content-center">
                                <button class="btn btn-sm @(string.IsNullOrEmpty(agendaStipula.Assegnatario) ? "btn-outline-success" : "btn-outline-danger") btn-toggle-assegnatario flex-fill" style="max-width: 100px;">
                                    <i class="fas @(string.IsNullOrEmpty(agendaStipula.Assegnatario) ? "fa-user-plus" : "fa-user-times")"></i>
                                    @(string.IsNullOrEmpty(agendaStipula.Assegnatario) ? "Assegna" : "Revoca")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @{
        int totalPages = (int) Math.Ceiling(Model.AgendaStipule.TotalCount / (decimal) Model.Input.Limit);
        int currentPage = Model.Input.Page;
    }

    @if (totalPages > 1)
    {
        <div class="card-footer d-flex justify-content-center">

            <nav aria-label="Paginazione">
                <ul class="pagination d-flex justify-content-center mt-3">
                    @if(currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-page="@(currentPage - 1)"><i class="fas fa-angle-left"></i></a>
                        </li>   
                    }
                    @for(int p = Math.Max(1, currentPage - 4); p <= Math.Min(totalPages, currentPage + 4); p++)
                    {
                        if (p == currentPage)
                        {
                            <li class="page-item active" aria-current="page">
                                <a class="page-link" asp-route-page="@p">@p <span class="sr-only">(current)</span></a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" asp-route-page="@p">@p</a>
                            </li>
                        }
                    }
                    @if(currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-page="@(currentPage + 1)"><i class="fas fa-angle-right"></i></a>
                        </li>   
                    }
                </ul>
            </nav>
        </div>
    }
</div>

<!-- SCRIPT AJAX ASSEGNA/REVOCA -->
@section Scripts {
    <script>
        const assignUrl = '@Url.Action("Assign", "AgendaStipule")';
        const revokeUrl = '@Url.Action("Revoke", "AgendaStipule")';

        document.querySelectorAll(".btn-toggle-assegnatario").forEach(function(button) {
            button.addEventListener("click", async function () {
                var row = button.closest("tr");
                if (!row) return;

                var idRichiesta = row.querySelector("td:nth-child(1)").textContent.trim();
                var cell = row.querySelector(".assegnatario");
                if (!cell) return;

                var actionUrl = button.classList.contains("btn-outline-success") ? assignUrl : revokeUrl;

                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                var formData = new FormData();
                formData.append("__RequestVerificationToken", token);
                formData.append("idRichiesta", idRichiesta);

                try {
                    var response = await fetch(actionUrl, {
                        method: "POST",
                        body: formData
                    });

                    if (!response.ok) throw new Error(`Server error: ${response.status}`);
                    var data = await response.json();

                    if (actionUrl === assignUrl) {
                        cell.textContent = data.assegnatario;
                        button.classList.remove("btn-outline-success");
                        button.classList.add("btn-outline-danger");
                        button.innerHTML = '<i class="fas fa-user-times"></i> Revoca';
                    } else {
                        cell.textContent = "";
                        button.classList.remove("btn-outline-danger");
                        button.classList.add("btn-outline-success");
                        button.innerHTML = '<i class="fas fa-user-plus"></i> Assegna';
                    }
                } catch (err) {
                    console.error("Fetch error:", err);
                    alert("Errore di rete. Controlla token CSRF o connessione.");
                }
            });
        });
    </script>
}